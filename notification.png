<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 500 500" width="500" height="500">
  <!-- Shadow effect -->
  <circle cx="255" cy="255" r="235" fill="#1a6b3a" opacity="0.3"/>
  <!-- Main outer circle - dark green border -->
  <circle cx="250" cy="250" r="235" fill="#1D8348"/>
  <!-- Inner circle - bright green -->
  <circle cx="250" cy="250" r="215" fill="#27AE60"/>
  <!-- Subtle inner ring -->
  <circle cx="250" cy="250" r="195" fill="none" stroke="white" stroke-width="2" opacity="0.2"/>
  <!-- PBCH text centered -->
  <text x="250" y="290" 
    text-anchor="middle" 
    font-family="Arial Black, Helvetica Neue, sans-serif" 
    font-size="120" 
    font-weight="900" 
    fill="white"
    letter-spacing="-2">PBCH</text>
  <!-- Subtle bottom shine -->
  <ellipse cx="250" cy="420" rx="140" ry="20" fill="white" opacity="0.06"/>
  <!-- Top highlight -->
  <ellipse cx="230" cy="100" rx="80" ry="40" fill="white" opacity="0.08"/>
</svg>
